{
  "name": "@rodrigo-barraza/service-library",
  "version": "0.1.0",
  "description": "Service Chassis — shared Express microservice bootstrap, MongoDB, MinIO, auth, health, and graceful shutdown",
  "type": "module",
  "module": "src/index.js",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./mongo": "./src/MongoManager.js",
    "./minio": "./src/MinioManager.js",
    "./auth": "./src/AuthMiddleware.js",
    "./health": "./src/HealthAggregator.js",
    "./shutdown": "./src/GracefulShutdown.js",
    "./cron": "./src/CronScheduler.js"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "vitest run"
  },
  "peerDependencies": {
    "express": ">=5.0.0",
    "mongodb": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    }
  },
  "dependencies": {
    "@rodrigo-barraza/utilities-library": "git+https://github.com/rodrigo-barraza/utilities-library.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "mongodb": "^7.2.0",
    "prettier": "^3.8.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigo-barraza/service-library.git"
  },
  "keywords": [
    "microservice",
    "express",
    "chassis",
    "bootstrap"
  ],
  "author": "Rodrigo Barraza <hello@rod.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
