{
  "name": "@rodrigo-barraza/service-library",
  "version": "0.2.0",
  "description": "Service Chassis — shared Express microservice bootstrap, MongoDB, MinIO, auth, health, and graceful shutdown",
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./mongo": {
      "types": "./src/MongoManager.ts",
      "import": "./dist/MongoManager.js"
    },
    "./minio": {
      "types": "./src/MinioManager.ts",
      "import": "./dist/MinioManager.js"
    },
    "./auth": {
      "types": "./src/AuthMiddleware.ts",
      "import": "./dist/AuthMiddleware.js"
    },
    "./health": {
      "types": "./src/HealthAggregator.ts",
      "import": "./dist/HealthAggregator.js"
    },
    "./shutdown": {
      "types": "./src/GracefulShutdown.ts",
      "import": "./dist/GracefulShutdown.js"
    },
    "./cron": {
      "types": "./src/CronScheduler.ts",
      "import": "./dist/CronScheduler.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "prepare": "[ -d node_modules/typescript ] && tsc || true",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && vitest run"
  },
  "peerDependencies": {
    "express": ">=5.0.0",
    "mongodb": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    }
  },
  "dependencies": {
    "@rodrigo-barraza/utilities-library": "github:rodrigo-barraza/utilities-library"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "minio": "^8.0.7",
    "mongodb": "^7.2.0",
    "prettier": "^3.8.3",
    "typescript": "next",
    "typescript-eslint": "^8.33.0",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigo-barraza/service-library.git"
  },
  "keywords": [
    "microservice",
    "express",
    "chassis",
    "bootstrap",
    "typescript"
  ],
  "author": "Rodrigo Barraza <hello@rod.dev>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
